{
  "name": "moozumi-official-view",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "dev": "node server",
    "start": "PORT=5172 node server.js",
    "verify-seo": "bash scripts/verify-seo.sh",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --ssrManifest --outDir dist/client && node scripts/defer-css.js",
    "build:server": "vite build --ssr src/entry-server.js --outDir dist/server",
    "preview": "cross-env NODE_ENV=production node server",
    "defer-css": "node scripts/defer-css.js"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "dependencies": {
    "@ant-design/icons-vue": "^6.1.0",
    "@vue/server-renderer": "^3.4.29",
    "@vueuse/core": "^10.4.0",
    "ant-design-vue": "^3.2.20",
    "axios": "^1.6.5",
    "compression": "^1.8.0",
    "dayjs": "^1.11.11",
    "express": "^5.0.1",
    "minimist": "^1.2.8",
    "pinia": "^3.0.2",
    "pinia-plugin-persist": "^1.0.0",
    "prompts": "^2.4.2",
    "sirv": "^3.0.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.3",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/qs": "^6.9.11",
    "@vitejs/plugin-vue": "^5.2.1",
    "cross-env": "^7.0.3",
    "less": "^4.3.0",
    "less-loader": "^12.2.0",
    "qs": "^6.11.2",
    "sitemap": "^9.0.1",
    "terser": "^5.27.0",
    "typescript": "~5.7.3",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.1.1",
    "vite-plugin-prerender": "^1.0.8",
    "vue-tsc": "^2.2.2",
    "wrangler": "^4.103.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "core-js",
      "puppeteer",
      "vue-demi"
    ]
  }
}
